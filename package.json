{
  "name": "anime-track-web",
  "version": "1.0.0",
  "private": true,
  "main": "dist-desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/deploy/prod_build_guard.js",
    "build:next": "next build",
    "deploy:prod": "bash scripts/deploy/deploy_production.sh",
    "start": "node scripts/deploy/prod_start_guard.js",
    "start:next": "next start",
    "lint": "next lint",
    "db:apply-sql": "node scripts/db/apply_sql_files.js",
    "db:init-with-anime-data": "node scripts/db/apply_sql_files.js database/schema.sql database/seed_anime_data.sql",
    "user:create-admin": "node scripts/db/create_admin_user.js",
    "db:export-anime-seed": "node scripts/db/export_anime_seed.js",
    "db:table-backup": "node scripts/db/export_table_backups.js",
    "db:full-backup": "node scripts/db/export_full_backup.js",
    "db:scheduled-backup": "node scripts/db/scheduled_backup.js",
    "covers:retry": "node scripts/retry-placeholder-covers.js",
    "anime:enrich-titles": "node scripts/enrich/enrich_titles.js",
    "anime:enrich-titles:write": "node scripts/enrich/enrich_titles.js --write",
    "anime:enrich-bangumi": "node scripts/enrich/enrich_bangumi.js",
    "anime:enrich-bangumi:write": "node scripts/enrich/enrich_bangumi.js --write",
    "covers:restore-sources": "node scripts/enrich/enrich_bangumi.js --covers-only",
    "covers:restore-sources:write": "node scripts/enrich/enrich_bangumi.js --covers-only --write",
    "desktop:prepare": "node scripts/desktop/prepare-standalone.js",
    "desktop:build:web": "npm run build:next && npm run desktop:prepare",
    "desktop:build:electron": "tsc -p desktop/tsconfig.json",
    "desktop:build": "npm run desktop:build:web && npm run desktop:build:electron",
    "desktop:rebuild-native": "electron-builder install-app-deps && node scripts/desktop/sync-native-modules.js .next/standalone/node_modules",
    "desktop:start": "npm run desktop:build && node scripts/desktop/run-electron.js",
    "desktop:pack": "npm run desktop:build && node scripts/desktop/package-electron.js dir",
    "desktop:dist": "npm run desktop:build && node scripts/desktop/package-electron.js portable"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.4",
    "next": "^14.1.0",
    "next-auth": "^4.24.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "swr": "^2.4.2",
    "typescript": "^5.3.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "appId": "com.animetrack.desktop",
    "productName": "AnimeTrack",
    "asar": true,
    "afterPack": "scripts/desktop/after-pack.js",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist-desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-desktop/standalone",
        "to": "app/standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "AnimeTrack-${version}-portable.${ext}"
    }
  }
}
