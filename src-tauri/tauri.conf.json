{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AnimeTrack",
  "version": "0.1.0",
  "identifier": "com.zmqqqa.animetrack",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build:desktop:vite"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AnimeTrack",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ],
        "template": "wix/main.wxs"
      },
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
